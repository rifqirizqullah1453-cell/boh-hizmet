{
  "name": "boh-hizmet-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:server": "npm run dev -w apps/server",
    "dev:client": "npm run dev -w apps/client",
    "dev:worker": "npm run dev -w apps/worker",
    "db:generate": "npm run db:generate -w packages/db",
    "db:migrate": "npm run db:migrate -w packages/db",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "emulators": "npx firebase-tools@13 emulators:start --only auth,firestore"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.4"
  }
}
