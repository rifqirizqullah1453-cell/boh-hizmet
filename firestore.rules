rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // active_orders is a read-only mirror for the Worker/Client Apps.
    // Every write (create on order.create, patch on accept/progress,
    // delete on COMPLETED/CANCELLED) goes through the server's Firebase
    // Admin SDK, which bypasses these rules entirely — so clients only
    // ever need read access here, never write.
    match /active_orders/{orderId} {
      // World-readable is intentional, not a placeholder: this collection
      // is the public job board (like Gojek's nearby-order broadcast) and
      // ActiveOrderDoc deliberately excludes sensitive fields (no customer
      // phone/address details — see packages/contracts/order.contract.ts).
      // If that contract ever grows to include sensitive data, this rule
      // must be tightened to `request.auth != null` at minimum.
      allow read: if true;
      allow write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
