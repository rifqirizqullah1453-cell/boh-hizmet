# ── SQL (Drizzle, source of truth) ──────────────────────────────
DATABASE_URL=                # mysql://user:pass@host:port/db
APP_SECRET=                  # used to sign/verify session JWTs

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated allowed origins for cookie-credentialed requests from the
# Worker/Client Vite dev servers. Defaults to localhost:5173,5174 if unset.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Firestore (real-time event bus, apps/server/src/services/firestore) ─
# Local emulator mode (recommended while building): leave FIREBASE_* blank,
# uncomment FIRESTORE_EMULATOR_HOST below, and run `npm run emulators` at
# the repo root first.
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_PROJECT_ID=demo-boh-hizmet
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Real project mode: comment out FIRESTORE_EMULATOR_HOST above, then fill
# these in from Firebase Console > Project Settings > Service Accounts >
# Generate new private key.
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=      # keep the \n escapes as-is; client.ts unescapes them
